# MaaS API (内网模型服务) - 请填写实际值
MAAS_API_KEY=your_maas_api_key
MAAS_HOST_IP=your_maas_host_ip
MAAS_URL=http://your_host_ip:port/your/api/path/v1/chat/completions

# Qwen Plus API (阿里云 DashScope) - 请填写实际值
QWEN_PLUS_API_KEY=your_qwen_plus_api_key
QWEN_PLUS_URL=https://dashscope.aliyuncs.com/compatible-mode/

# 本地部署模型（local_qwen）- 内网自托管推理服务
LOCAL_MODEL_NAME=qwen3-14b
LOCAL_HOST_IP=your_local_host_ip
LOCAL_HOST_PORT=8113
LOCAL_URL=/v1/chat/completions
LOCAL_CONCURRENCY=100

# 打分模型（LLM Judge）
SCORE_MODEL_NAME=model_name_here
SCORE_API_KEY=apikey_here
SCORE_HOST_IP=service_ip_here
SCORE_HOST_PORT=service_port_here
# 注意：SCORE_MODEL_TYPE=vllm 时，URL 只需填 base 路径（不含 v1/chat/completions），会自动追加
SCORE_URL=url_here
SCORE_LLM_CONCURRENCY=5
# SCORE_MODEL_TYPE: maas（默认，使用 MaaSAPI）或 vllm（使用 VLLMCustomAPIChat，适用于百炼等 OpenAI 兼容接口）
SCORE_MODEL_TYPE=maas
